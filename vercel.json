{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/_backend/:path*",
      "destination": "/backend/:path*"
    }
  ],
  "functions": {
    "backend/app/api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{backend/tests/**,backend/venv/**,backend/alembic/**,backend/.env,backend/.env.example,backend/Dockerfile,**/__pycache__/**}"
    }
  }
}
